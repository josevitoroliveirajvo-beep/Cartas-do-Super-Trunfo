#include <stdio.h>

int main() {

    /* ==========================
       Dados da Carta 1
    ========================== */

    char estado1 = 'A';
    char codigo1[] = "A01";
    char cidade1[] = "Sao Paulo";
    int populacao1 = 12325000;
    float area1 = 1521.11;
    float pib1 = 699.28;
    int pontos1 = 50;

    /* ==========================
       Dados da Carta 2
    ========================== */

    char estado2 = 'B';
    char codigo2[] = "B02";
    char cidade2[] = "Rio de Janeiro";
    int populacao2 = 6748000;
    float area2 = 1200.25;
    float pib2 = 300.50;
    int pontos2 = 30;

    int opcao;
    int opcao2;

    float valor1, valor2;
    float soma1, soma2;

    /* ==========================
       Exibição das cartas
    ========================== */

    printf("=== CARTA 1 ===\n");
    printf("Estado: %c\n", estado1);
    printf("Codigo: %s\n", codigo1);
    printf("Cidade: %s\n", cidade1);
    printf("Populacao: %d\n", populacao1);
    printf("Area: %.2f km²\n", area1);
    printf("PIB: %.2f bilhoes\n", pib1);
    printf("Pontos Turisticos: %d\n\n", pontos1);

    printf("=== CARTA 2 ===\n");
    printf("Estado: %c\n", estado2);
    printf("Codigo: %s\n", codigo2);
    printf("Cidade: %s\n", cidade2);
    printf("Populacao: %d\n", populacao2);
    printf("Area: %.2f km²\n", area2);
    printf("PIB: %.2f bilhoes\n", pib2);
    printf("Pontos Turisticos: %d\n\n", pontos2);

    /* ==========================
       MENU DE COMPARAÇÃO
    ========================== */

    printf("=== SUPER TRUNFO ===\n");
    printf("Escolha o atributo para comparar:\n");
    printf("1 - Populacao\n");
    printf("2 - Area\n");
    printf("3 - PIB\n");
    printf("4 - Pontos Turisticos\n");

    scanf("%d", &opcao);

    switch(opcao)
    {
        case 1:
            valor1 = populacao1;
            valor2 = populacao2;
        break;

        case 2:
            valor1 = area1;
            valor2 = area2;
        break;

        case 3:
            valor1 = pib1;
            valor2 = pib2;
        break;

        case 4:
            valor1 = pontos1;
            valor2 = pontos2;
        break;

        default:
            printf("Opcao invalida!\n");
            return 0;
    }

    /* ==========================
       Comparação simples
    ========================== */

    if(valor1 > valor2)
    {
        printf("\nCarta 1 venceu! (%s)\n", cidade1);
    }
    else if(valor2 > valor1)
    {
        printf("\nCarta 2 venceu! (%s)\n", cidade2);
    }
    else
    {
        printf("\nEmpate!\n");
    }

    /* ==========================
       Comparação com 2 atributos
    ========================== */

    printf("\nEscolha um SEGUNDO atributo:\n");
    printf("1 - Populacao\n");
    printf("2 - Area\n");
    printf("3 - PIB\n");
    printf("4 - Pontos Turisticos\n");

    scanf("%d", &opcao2);

    switch(opcao2)
    {
        case 1:
            soma1 = valor1 + populacao1;
            soma2 = valor2 + populacao2;
        break;

        case 2:
            soma1 = valor1 + area1;
            soma2 = valor2 + area2;
        break;

        case 3:
            soma1 = valor1 + pib1;
            soma2 = valor2 + pib2;
        break;

        case 4:
            soma1 = valor1 + pontos1;
            soma2 = valor2 + pontos2;
        break;

        default:
            printf("Opcao invalida!\n");
            return 0;
    }

    /* ==========================
       Operador ternário
    ========================== */

    printf("\nResultado Final:\n");

    (soma1 > soma2) ?
        printf("Carta 1 venceu! Cidade: %s\n", cidade1) :
        (soma2 > soma1) ?
            printf("Carta 2 venceu! Cidade: %s\n", cidade2) :
            printf("Empate!\n");

    return 0;
}
